{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "dist/client",
    "rootDir": "extention/src",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true
