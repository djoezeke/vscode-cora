{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Cora",
	"scopeName": "source.cora",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#docstrings"
		},
		{
			"include": "#class-definition"
		},
		{
			"include": "#function-definition"
		},
		{
			"include": "#imports"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#constants"
		},
		{
			"include": "#types"
		},
		{
			"include": "#annotations"
		},
		{
			"include": "#operators"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#member-access"
		}
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.number-sign.cora",
					"match": "#.*$"
				},
				{
					"name": "comment.line.double-slash.cora",
					"match": "//.*$"
				},
				{
					"name": "comment.block.c-style.cora",
					"begin": "/\\*",
					"end": "\\*/"
				}
			]
		},
		"docstrings": {
			"name": "comment.block.documentation.cora",
			"begin": "\"\"\"",
			"end": "\"\"\"",
			"patterns": [
				{
					"name": "keyword.other.documentation.tag.cora",
					"match": "@[A-Za-z_][A-Za-z0-9_]*"
				}
			]
		},
		"class-definition": {
			"patterns": [
				{
					"name": "meta.class.cora",
					"match": "\\b(class)\\s+([A-Za-z_][A-Za-z0-9_]*)",
					"captures": {
						"1": {
							"name": "keyword.declaration.class.cora"
						},
						"2": {
							"name": "entity.name.type.class.cora"
						}
					}
				}
			]
		},
		"function-definition": {
			"patterns": [
				{
					"name": "meta.function.cora",
					"match": "\\b(fun)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
					"captures": {
						"1": {
							"name": "keyword.declaration.function.cora"
						},
						"2": {
							"name": "entity.name.function.cora"
						}
					}
				}
			]
		},
		"imports": {
			"patterns": [
				{
					"name": "meta.import.cora",
					"match": "\\b(import)\\s+([A-Za-z_][A-Za-z0-9_]*)",
					"captures": {
						"1": {
							"name": "keyword.control.import.cora"
						},
						"2": {
							"name": "entity.name.namespace.cora"
						}
					}
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "storage.modifier.cora",
					"match": "\\b(pub|const|let)\\b"
				},
				{
					"name": "keyword.control.cora",
					"match": "\\b(if|else|while|for|return|break|continue)\\b"
				},
				{
					"name": "variable.language.this.cora",
					"match": "\\b(this)\\b"
				}
			]
		},
		"constants": {
			"patterns": [
				{
					"name": "constant.language.boolean.cora",
					"match": "\\b(true|false)\\b"
				},
				{
					"name": "constant.language.null.cora",
					"match": "\\b(null|none)\\b"
				}
			]
		},
		"types": {
			"patterns": [
				{
					"name": "storage.type.cora",
					"match": "\\b(int|float|str|string|bool|job|void)\\b"
				}
			]
		},
		"annotations": {
			"patterns": [
				{
					"name": "entity.other.attribute-name.annotation.cora",
					"match": "@[A-Za-z_][A-Za-z0-9_]*"
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.assignment.cora",
					"match": "(->|:=|=)"
				},
				{
					"name": "keyword.operator.arithmetic.cora",
					"match": "[+\\-*/%]"
				},
				{
					"name": "keyword.operator.comparison.cora",
					"match": "(==|!=|<=|>=|<|>)"
				},
				{
					"name": "keyword.operator.logical.cora",
					"match": "\\b(and|or|not)\\b"
				}
			]
		},
		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.cora",
					"match": "\\b\\d+(?:\\.\\d+)?\\b"
				}
			]
		},
		"member-access": {
			"patterns": [
				{
					"name": "variable.other.property.cora",
					"match": "(?<=\\.)[A-Za-z_][A-Za-z0-9_]*"
				}
			]
		},
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.double.cora",
					"begin": "\"",
					"end": "\"",
					"patterns": [
						{
							"name": "constant.character.escape.cora",
							"match": "\\\\."
						}
					]
				},
				{
					"name": "string.quoted.single.cora",
					"begin": "'",
					"end": "'",
					"patterns": [
						{
							"name": "constant.character.escape.cora",
							"match": "\\\\."
						}
					]
				}
			]
		}
	}
}