{
  "colorizedBracketPairs": [],
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["'", "'"],
    ["\"", "\""],
    ["/*", "*/"],
    ["\"\"\"", "\"\"\""]
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"\"\"", "\"\"\""],
    ["\"", "\""],
    ["'", "'"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(class|fun)\\b.*$",
      "end": "^\\s*\\}\\s*$"
    }
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*(class|fun|if|else|while|for)\\b.*(:|\\{)?\\s*$",
      "action": {
        "indent": "indent"
      }
    }
  ]
}
